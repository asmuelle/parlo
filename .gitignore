# Xcode (generated by xcodegen — never commit)
*.xcodeproj
*.xcworkspace
xcuserdata/
DerivedData/

# Swift Package Manager
.build/
.swiftpm/
Packages/*/.build/

# Model weights & compiled ML assets (fetched/converted at build time, never committed)
*.gguf
*.mlmodelc
*.mlpackage/Data/weights/

# Build artifacts
*.ipa
*.dSYM
*.dSYM.zip
build/

# Environment / secrets (CI-only; never in repo)
.env
*.p8
*.mobileprovision

# macOS
.DS_Store

# Claude Code local overrides
.claude/settings.local.json
